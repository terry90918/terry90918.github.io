# 網站設定
NEXT_PUBLIC_SITE_URL=https://lawyer.jurislm.com

# ===========================
# Payload CMS 設定
# ===========================
# PostgreSQL 資料庫連線
DATABASE_URL=postgres://user:password@localhost:5432/lawyer_cms

# Payload Secret（JWT 簽名用，至少 32 字元隨機字串）
PAYLOAD_SECRET=your-payload-secret-at-least-32-chars

# ===========================
# S3 儲存設定（MinIO）
# ===========================
S3_BUCKET=lawyer-media
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_ENDPOINT=https://s3.jurislm.com
S3_REGION=us-east-1

# ===========================
# Staging 設定
# ===========================
# STAGING=true

# ===========================
# E2E 測試設定（可選）
# ===========================
# E2E_ADMIN_EMAIL=e2e-test@jurislm.com
# E2E_ADMIN_PASSWORD=your_e2e_password

# ===========================
# 社群媒體 API 設定
# ===========================

# Facebook Page API
# 1. 前往 https://developers.facebook.com 建立 App
# 2. 新增 Facebook Login 和 Pages API 權限
# 3. 取得粉絲專頁存取權杖 (需要 pages_read_engagement, pages_manage_posts 權限)
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# Instagram Business API
# 1. Instagram 帳號需要轉為專業帳號並連結到 Facebook 粉絲專頁
# 2. 使用 Facebook Graph API 取得 Instagram Business Account ID
# 3. 存取權杖需要 instagram_basic, instagram_content_publish 權限
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# LINE API
# 方案一: LINE Notify (較簡單，適合推播通知)
# 前往 https://notify-bot.line.me 申請
LINE_NOTIFY_ACCESS_TOKEN=your_line_notify_token

# 方案二: LINE Official Account Messaging API (較完整，可發送 Flex Message)
# 1. 前往 https://manager.line.biz 建立 Official Account
# 2. 在 LINE Developers Console 取得 Channel Access Token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_BROADCAST_ENABLED=true
